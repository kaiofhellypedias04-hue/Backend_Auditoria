APP_ENV=production
PORT=10000
# Banco
DATABASE_URL=postgresql://backend_auditoria_user:0Jiu9BSj3nfnoACmmkHjB8aWaLmRzQ5F@dpg-d71tcqq4d50c73bvsvrg-a/backend_auditoria
DB_SSLMODE=
DB_CONNECT_TIMEOUT=15

# Runtime paths
APP_DATA_DIR=/tmp/backend_render_ready
DATA_DIR=/tmp/backend_render_ready/saida
OUTPUT_DIR=/tmp/backend_render_ready/saida
TEMP_DIR=/tmp/backend_render_ready/temp
CERTS_DIR=/tmp/backend_render_ready/certs
CERTS_JSON_PATH=/tmp/backend_render_ready/certs.json
CREDENTIALS_JSON_PATH=/tmp/backend_render_ready/credentials.json
SECRETS_FILE_PATH=/tmp/backend_render_ready/secrets.runtime.json

# API / CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Node / Playwright
NODE_BIN=node
NPM_BIN=npm
PLAYWRIGHT_SCRIPT_PATH=./playwright_nfse_download.js
PACKAGE_JSON_PATH=./package.json
PLAYWRIGHT_TIMEOUT_MS=300000
NODE_OPTIONS=--openssl-legacy-provider

# Segredos para certificados/credenciais
# Use um dos formatos abaixo:
# 1) Por alias normalizado: CERT_PASSWORD_MEU_ALIAS=senha
# 2) JSON completo: CERT_PASSWORDS_JSON={"Meu Alias":"senha"}
# 3) Pela própria API, que salva em SECRETS_FILE_PATH
CERT_PASSWORDS_JSON={}
CREDENTIAL_PASSWORDS_JSON={}
ENABLE_KEYRING_FALLBACK=true

# Exemplo por alias
# CERT_PASSWORD_MEU_ALIAS=senha-do-certificado
# CREDENTIAL_PASSWORD_EMPRESA_X=senha-do-portal

# API Invertexto
INVERTEXTO_TOKEN=24813|XnhUeOW389li148hhvxGPlhjBof4LoOF
INVERTEXTO_RPM=30
INVERTEXTO_DELAY_SECONDS=0.6

# S3 / MinIO (opcional)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nfse-storage
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
