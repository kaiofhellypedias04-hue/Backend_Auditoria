APP_ENV=production
PORT=10000

# Banco
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_SSLMODE=
DB_CONNECT_TIMEOUT=15

# Runtime temporario em /tmp
APP_DATA_DIR=/tmp/backend_render_ready
DATA_DIR=/tmp/backend_render_ready/saida
OUTPUT_DIR=/tmp/backend_render_ready/saida
TEMP_DIR=/tmp/backend_render_ready/temp
CERTS_DIR=/tmp/backend_render_ready/certs
CERTS_JSON_PATH=/tmp/backend_render_ready/certs.json
CREDENTIALS_JSON_PATH=/tmp/backend_render_ready/credentials.json
SECRETS_FILE_PATH=/tmp/backend_render_ready/secrets.runtime.json

# API / CORS
CORS_ORIGINS=https://seu-frontend.onrender.com

# Node / Playwright
NODE_BIN=node
NPM_BIN=npm
PLAYWRIGHT_SCRIPT_PATH=./playwright_nfse_download.js
PACKAGE_JSON_PATH=./package.json
PLAYWRIGHT_TIMEOUT_MS=300000
NODE_OPTIONS=--openssl-legacy-provider

# Segredos
CERT_PASSWORDS_JSON={}
CREDENTIAL_PASSWORDS_JSON={}
ENABLE_KEYRING_FALLBACK=false

# API Invertexto
INVERTEXTO_TOKEN=
INVERTEXTO_RPM=30
INVERTEXTO_DELAY_SECONDS=0.6

# S3 / MinIO opcional
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
